# --- VLM credentials ---
# Either OPENROUTER_API_KEY or ANTHROPIC_API_KEY unlocks Phase 2 VLM mode.
# OpenRouter is the recommended path: ~+5% over direct Anthropic, no
# console.anthropic.com account needed, single key works for many models.

OPENROUTER_API_KEY=sk-or-v1-...   # https://openrouter.ai/keys (preferred)
ANTHROPIC_API_KEY=                # https://console.anthropic.com/keys
OPENAI_API_KEY=                   # optional cross-provider tests

# Backend selection: "auto" (openrouter > anthropic), "anthropic", "openrouter"
VLM_BACKEND=auto

# --- Default models ---
PRIMARY_VLM=claude-sonnet-4-6
SECONDARY_VLM=qwen2.5-vl-72b   # via local vLLM (Phase 2)

# --- Geospatial ---
SENTINEL_STAC_URL=https://earth-search.aws.element84.com/v1
PLANETARY_COMPUTER_KEY=

# --- OpenAlex / others ---
OPENALEX_EMAIL=your.email@example.com   # courtesy header (improves rate limit)
SEMANTIC_SCHOLAR_API_KEY=

# --- DB ---
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Storage ---
DATA_DIR=./data
COG_DIR=./data/cogs
CACHE_DIR=./data/cache

# --- Runtime ---
LOG_LEVEL=INFO
ENABLE_PROMPT_CACHING=true
